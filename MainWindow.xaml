                </TextBlock>

                <!--Chatbot Title-->
                <TextBlock Text="ZENSHIELD AWARENESS BOT"
                           FontFamily="Consolas"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="#FF00FF"
                           HorizontalAlignment="Center"
                           Margin="0,5,0,2"/>


                <TextBlock Text="Together We Stay Cyber Safe Always 🔒"
                           FontFamily="Consolas"
                           FontSize="10"
                           Foreground="#00CCCC"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,5"/>
            </StackPanel>
        </Border>


        <TabControl Grid.Row="1"
                    x:Name="mainTabControl"
                    Background="#0A0A14"
                    BorderBrush="#00FFFF"
                    BorderThickness="0">



            <!--Defines the visual appearance of the tab items-->
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="#070710"/>
                    <Setter Property="Foreground" Value="#00FFFF"/>
                    <Setter Property="FontFamily" Value="Consolas"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Padding" Value="22,12"/>
                    <Setter Property="BorderBrush" Value="#00FFFF"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">

                                <Border x:Name="tabBorder"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="#00FFFF"
                                        BorderThickness="0,0,0,3"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter ContentSource="Header"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>


                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="tabBorder" Property="Background" Value="#1E1E32"/>
                                        <Setter TargetName="tabBorder" Property="BorderBrush" Value="#FF00FF"/>
                                        <Setter Property="Foreground" Value="#FF00FF"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="tabBorder" Property="Background" Value="#12122A"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>



            <!--Chat Tab-->
            <TabItem Header="💬  Chat" Width="220">
                <Grid Background="#0F0F1A">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>


                    <!--Chat History Section-->
                    <Border Grid.Row="0"
                            Background="#0F0F1A"
                            Margin="10,10,10,5">


                        <ScrollViewer x:Name="scrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="5">


                            <!--Chat history will be displayed in this area-->
                            <RichTextBox x:Name="chatHistorySection"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         IsReadOnly="True"
                                         FontFamily="Consolas"
                                         FontSize="11"
                                         Foreground="White"
                                         Padding="10"
                                         VerticalScrollBarVisibility="Disabled"/>

                        </ScrollViewer>
                    </Border>

                    <!--User Input Section-->
                    <Border Grid.Row="1"
                            Background="#0A0A14"
                            BorderBrush="#00FFFF"
                            BorderThickness="0,2,0,0"
                            Padding="10">


                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>


                            <Grid Grid.Column="0">
                                <TextBox x:Name="txtUserInput"
                                    Background="#1E1E32"
                                    Foreground="White"
                                    CaretBrush="White"
                                    BorderBrush="#00FFFF"
                                    BorderThickness="1"
                                    FontFamily="Consolas"
                                    FontSize="11"
                                    Padding="10,8"
                                    Margin="0,0,10,0"
                                    KeyDown="txtUserInput_KeyDown"
                                    TextChanged="txtUserInput_TextChanged"
                                    VerticalContentAlignment="Center"/>


                                <TextBlock x:Name="txtPlaceholder"
                                       Text="Type your message here..."
                                       Margin="5,7,0,0"
                                       Foreground="#FF808080"
                                       IsHitTestVisible="False"/>
                            </Grid>


                            <!--A send button that the user clicks for clearing messages-->
                            <Button x:Name="btnClear"
                                    Grid.Column="1"
                                    Content="Clear"
                                    Background="#3A1A1A"
                                    Foreground="#FF4444"
                                    BorderBrush="#FF4444"
                                    BorderThickness="1"
                                    FontFamily="Consolas"
                                    FontSize="11"
                                    Padding="15,8"
                                    Cursor="Hand"
                                    Click="btnClear_Click">
                                <Button.Template>

                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="8"
                                            Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>


                            <!--A send button that the user clicks for sending messages-->
                            <Button x:Name="btnSend"
                                    Grid.Column="2"
                                    Content="Send"
                                    Background="#00FFFF"
                                    Foreground="#0A0A14"
                                    FontFamily="Consolas"
                                    FontSize="11"
                                    FontWeight="Bold"
                                    BorderThickness="0"
                                    Padding="20,8"
                                    Cursor="Hand"
                                    Click="btnSend_Click">
                                <Button.Template>

                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                            CornerRadius="8"
                                            Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                        </Grid>
                    </Border>
                </Grid>
            </TabItem>



            <!-- Tasks Tab -->
            <TabItem Header="📋  Tasks" Width="220">
                <Grid Background="#0F0F1A" Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>


                    <TextBlock Grid.Row="0"
                                       Text="📋  CYBERSECURITY TASK ASSISTANT"
                                       FontFamily="Consolas"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="#FF00FF"
                                       Margin="0,0,0,12"/>


                    <!-- Add New Task Form -->
                    <Border Grid.Row="1"
                                    Background="#0A0A14"
                                    BorderBrush="#00FFFF"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="14"
                                    Margin="0,0,0,12">
                        <StackPanel>


                            <TextBlock Text="➕  ADD NEW TASK"
                                       FontFamily="Consolas"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="#00FFFF"
                                       Margin="0,0,0,12"/>


                            <!-- Task Title Field -->
                            <TextBlock Text="Task Title (required)"
                                       FontFamily="Consolas"
                                       FontSize="10"
                                       Foreground="#555577"
                                       Margin="0,0,0,4"/>


                            <Border BorderBrush="#00FFFF" BorderThickness="1" CornerRadius="6" Margin="0,0,0,10">
                                <TextBox x:Name="txtTaskTitle"
                                         Background="#1E1E32"
                                         Foreground="White"
                                         CaretBrush="White"
                                         BorderThickness="0"
                                         FontFamily="Consolas"
                                         FontSize="11"
                                         Padding="10,8"/>
                            </Border>


                            <!-- Task Description Field -->
                            <TextBlock Text="Task Description (optional)"
                                       FontFamily="Consolas"
                                       FontSize="10"
                                       Foreground="#555577"
                                       Margin="0,0,0,4"/>
                            <Border BorderBrush="#00FFFF" BorderThickness="1" CornerRadius="6" Margin="0,0,0,10">
                                <TextBox x:Name="txtTaskDescription"
                                         Background="#1E1E32"
                                         Foreground="White"
                                         CaretBrush="White"
                                         BorderThickness="0"
                                         FontFamily="Consolas"
                                         FontSize="11"
                                         Padding="10,8"
                                         Height="55"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         AcceptsReturn="True"/>
                            </Border>


                            <!-- Reminder Date Field -->
                            <TextBlock Text="Reminder Date (optional)"
                                       FontFamily="Consolas"
                                       FontSize="10"
                                       Foreground="#555577"
                                       Margin="0,0,0,4"/>
                            <Border BorderBrush="#00FFFF" BorderThickness="1" CornerRadius="6" Margin="0,0,0,12">
                                <DatePicker x:Name="dpReminderDate"
                                            Background="#1E1E32"
                                            Foreground="White"
                                            BorderThickness="0"
                                            FontFamily="Consolas"
                                            FontSize="11"
                                            Padding="8,6"/>
                            </Border>


                            <Button x:Name="btnAddTask"
                                    Content="+ Add Task"
                                    Background="#00FFFF"
                                    Foreground="#0A0A14"
                                    FontFamily="Consolas"
                                    FontSize="11"
                                    FontWeight="Bold"
                                    BorderThickness="0"
                                    Padding="18,9"
                                    HorizontalAlignment="Left"
                                    Cursor="Hand"
                                    Click="btnAddTask_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Displays all the tasks saved for the current user -->
                    <Border Grid.Row="2"
                            Background="#0A0A14"
                            BorderBrush="#00FFFF"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="8"
                            Margin="0,0,0,12">
                        <StackPanel>

                            <TextBlock Text="YOUR SAVED TASKS"
                                       FontFamily="Consolas"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="#00FFFF"
                                       Margin="6,6,0,8"/>

                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="250">


                                <ListBox x:Name="lvTasks"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     FontFamily="Consolas"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     SelectionChanged="lvTasks_SelectionChanged">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Padding" Value="14,12"/>
                                            <Setter Property="Margin" Value="2,4"/>
                                            <Setter Property="MinHeight" Value="50"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">

                                                        <Border x:Name="itemBorder"
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="#1E1E32"
                                                            BorderThickness="0,0,0,1"
                                                            CornerRadius="6"
                                                            Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>


                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="itemBorder" Property="Background" Value="#1E1E32"/>
                                                                <Setter TargetName="itemBorder" Property="BorderBrush" Value="#00FFFF"/>
                                                                <Setter TargetName="itemBorder" Property="BorderThickness" Value="1"/>
                                                            </Trigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="itemBorder" Property="Background" Value="#12122A"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            
                                            <StackPanel Margin="0,4">


                                                <TextBlock Text="{Binding TitleDisplay}"
                                                       FontFamily="Consolas"
                                                       FontSize="14"
                                                       FontWeight="Bold"
                                                       Foreground="{Binding TitleColor}"/>


                                                <TextBlock Text="{Binding Description}"
                                                       FontFamily="Consolas"
                                                       FontSize="11"
                                                       Foreground="#888888"
                                                       Visibility="{Binding DescriptionVisibility}"
                                                       Margin="0,2,0,0"/>


                                                <TextBlock Text="{Binding ReminderDisplay}"
                                                       FontFamily="Consolas"
                                                       FontSize="11"
                                                       Foreground="#9B59B6"
                                                       Visibility="{Binding ReminderVisibility}"
                                                       Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>

                    <!-- Action Buttons for completing or deleting tasks -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,4">
                        <Button x:Name="btnCompleteTask"
                                Content="✅  Mark Complete"
                                Background="#1A3A1A"
                                Foreground="#00FF00"
                                BorderBrush="#00FF00"
                                BorderThickness="2"
                                FontFamily="Consolas"
                                FontSize="11"
                                FontWeight="Bold"
                                Padding="14,9"
                                Margin="0,0,10,0"
                                Cursor="Hand"
                                Click="btnCompleteTask_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>


                        <Button x:Name="btnDeleteTask"
                                Content="🗑  Delete Task"
                                Background="#3A1A1A"
                                Foreground="#FF4444"
                                BorderBrush="#FF4444"
                                BorderThickness="2"
                                FontFamily="Consolas"
                                FontSize="11"
                                FontWeight="Bold"
                                Padding="14,9"
                                Cursor="Hand"
                                Click="btnDeleteTask_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>


                        <TextBlock x:Name="txtTaskStatus"
                                   Text="Select a task from the list above then click an action button"
                                   FontFamily="Consolas"
                                   FontSize="10"
                                   Foreground="#555577"
                                   VerticalAlignment="Center"
                                   Margin="14,0,0,0"/>
                    </StackPanel>
                </Grid>
            </TabItem>



            <!--Quiz Tab-->
            <TabItem Header="🎮  Quiz" Width="220">
                
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid Background="#0F0F1A" Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    
                            <Grid Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="🎮  CYBERSECURITY QUIZ"
                                   FontFamily="Consolas"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="#FF00FF"
                                   HorizontalAlignment="Left"/>
                        <TextBlock Text="How Cyber Safe Are You?"
                                   FontFamily="Consolas"
                                   FontSize="10"
                                   Foreground="#00FFFF"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"/>
                    </Grid>


                    <!-- Progress Bar shows the user's progress through the quiz -->
                    <Border Grid.Row="1"
                            Background="#1E1E32"
                            CornerRadius="4"
                            Height="8"
                            Margin="0,0,0,14">
                        <ProgressBar x:Name="progressQuiz"
                                     Background="Transparent"
                                     Foreground="#00FFFF"
                                     BorderThickness="0"
                                     Maximum="11"
                                     Value="0"/>
                    </Border>


                    <!-- Displays the current quiz question and its details -->
                    <Border Grid.Row="2"
                            Background="#0A0A14"
                            BorderBrush="#00FFFF"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="14"
                            Margin="0,0,0,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                <Border Background="#1E1E32" CornerRadius="12" Padding="6,3" HorizontalAlignment="Left">
                                    <TextBlock Text="Multiple Choice"
                                               FontFamily="Consolas"
                                               FontSize="10"
                                               Foreground="#888888"/>
                                </Border>


                                <TextBlock x:Name="txtQuizCounter"
                                           Text="Question 0 of 11"
                                           FontFamily="Consolas"
                                           FontSize="10"
                                           Foreground="#888888"
                                           HorizontalAlignment="Right"/>
                            </Grid>


                            <TextBlock Grid.Row="1"
                                       x:Name="txtQuizQuestion"
                                       Text="Are you ready? Let's play! Click 'Start Quiz' to begin!"
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       Foreground="#00FFFF"
                                       TextWrapping="Wrap"
                                       MinHeight="45"/>
                        </Grid>
                    </Border>


                    <StackPanel Grid.Row="3"
                                x:Name="quizOptionsPanel"
                                Orientation="Vertical"
                                Margin="0,0,0,10"/>


                    <!-- Feedback Box to show whether the user's answers are wrong or right -->
                    <Border Grid.Row="4"
                            x:Name="feedbackBorder"
                            CornerRadius="10"
                            BorderThickness="1"
                            Visibility="Collapsed"
                            Padding="12"
                            Margin="0,0,0,10">
                        <TextBlock x:Name="txtQuizFeedback"
                                   FontFamily="Consolas"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   LineHeight="18"/>
                    </Border>


                        <StackPanel Grid.Row="5" Orientation="Horizontal">
                            <Button x:Name="btnStartQuiz"
                                Content="▶  Start Quiz"
                                Background="#00FFFF"
                                Foreground="#0A0A14"
                                FontFamily="Consolas"
                                FontSize="11"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Padding="18,9"
                                Margin="0,0,10,0"
                                Cursor="Hand"
                                Click="btnStartQuiz_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>


                            <Button x:Name="btnNextQuestion"
                                Content="Next Question  ▶"
                                Background="#1E1E32"
                                Foreground="#00FFFF"
                                BorderBrush="#00FFFF"
                                BorderThickness="2"
                                FontFamily="Consolas"
                                FontSize="11"
                                Padding="18,9"
                                Margin="0,0,10,0"
                                Cursor="Hand"
                                Visibility="Collapsed"
                                Click="btnNextQuestion_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>


                            <Button x:Name="btnRestartQuiz"
                                Content="↺  Restart Quiz"
                                Background="#1E1E32"
                                Foreground="#00FFFF"
                                BorderBrush="#00FFFF"
                                BorderThickness="2"
                                FontFamily="Consolas"
                                FontSize="11"
                                Padding="18,9"
                                Cursor="Hand"
                                Click="btnRestartQuiz_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>



            <!--Activity Log Tab-->
            <TabItem Header="📜  Activity Log" Width="220">
                <Grid Background="#0F0F1A" Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="📜  ACTIVITY LOG"
                               FontFamily="Consolas"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="#FF00FF"
                               Margin="0,0,0,12"/>

                    <Border Grid.Row="1"
                            Background="#0A0A14"
                            BorderBrush="#00FFFF"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10"
                            Margin="0,0,0,12">

                        <!--ScrollViewer enables scrolling for long entry list-->
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="activityLogList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>


                                        <Border BorderBrush="#1E1E32"
                                                BorderThickness="0,0,0,1"
                                                Padding="6,8">


                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="55"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>


                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Time}"
                                                           FontFamily="Consolas"
                                                           FontSize="10"
                                                           FontWeight="Bold"
                                                           Foreground="#FFFFFF"
                                                           VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal">

                                                    <Border Background="{Binding BadgeBackground}"
                                                            CornerRadius="10"
                                                            Padding="8,3"
                                                            Margin="0,0,8,0">


                                                        <TextBlock Text="{Binding Badge}"
                                                                   FontFamily="Consolas"
                                                                   FontSize="10"
                                                                   Foreground="{Binding BadgeColor}"/>
                                                    </Border>


                                                    <TextBlock Text="{Binding Description}"
                                                               FontFamily="Consolas"
                                                               FontSize="10"
                                                               Foreground="#CCCCCC"
                                                               VerticalAlignment="Center"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>


                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                        <Button x:Name="btnRefreshLog"
                                Content="↺  Refresh"
                                Background="#1E1E32"
                                Foreground="#00FFFF"
                                BorderBrush="#00FFFF"
                                BorderThickness="2"
                                FontFamily="Consolas"
                                FontSize="11"
                                Padding="14,9"
                                Margin="0,0,10,0"
                                Cursor="Hand"
                                Click="btnRefreshLog_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>


                        <Button x:Name="btnShowMoreLog"
                                Content="Show More"
                                Background="#1E1E32"
                                Foreground="#00FFFF"
                                BorderBrush="#00FFFF"
                                BorderThickness="2"
                                FontFamily="Consolas"
                                FontSize="11"
                                Padding="14,9"
                                Cursor="Hand"
                                Click="btnShowMoreLog_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </TabItem>

        </TabControl>




        <!--Status Bar displays the bot's operational status and current time-->
        <Border Grid.Row="2"
                Background="#070710"
                BorderBrush="#1E1E32"
                BorderThickness="0,1,0,0"
                Padding="14,7">
            <Grid>
                <TextBlock x:Name="txtStatusBar"
                           Text="● ZenShield is ready"
                           FontFamily="Consolas"
                           FontSize="10"
                           Foreground="#00FF00"
                           HorizontalAlignment="Left"/>
                <TextBlock x:Name="txtDateTime"
                           FontFamily="Consolas"
                           FontSize="10"
                           Foreground="#555577"
                           HorizontalAlignment="Right"/>
            </Grid>
        </Border>

    </Grid>

</Window>
