<Window x:Class="ST10483814_POE_PART_3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        xmlns:local="clr-namespace:ST10483814_POE_PART_3"
        mc:Ignorable="d"
        Loaded="MainWindow_Loaded"
        Title="ZenShield Awareness Bot" Height="700" Width="900"
        WindowStartupLocation="CenterScreen">


    <Grid>
        <!-- Defines 3 rows in the container-->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!--Main Header Section-->
        <Border Grid.Row="0"
                Background="#0A0A14"
                BorderBrush="#00FFFF"
                BorderThickness="0,0,0,2"
                Padding="15">
            <StackPanel>

                <TextBlock FontFamily="Consolas"
                       FontSize="8"
                       Foreground="#00FFFF"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Margin="0,5,0,5"
                       xml:space="preserve" Height="148" Width="497">

 ██████╗██╗   ██╗██████╗ ███████╗██████╗ ███████╗███████╗ ██████╗██╗   ██╗██████╗ ██╗████████╗██╗   ██╗       
